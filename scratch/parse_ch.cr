hex = ""
bytes = hex.hexbytes
io = IO::Memory.new(bytes)

# Read Handshake Type
type = io.read_byte
puts "Type: #{type}"

# Read Length
len_bytes = Bytes.new(3)
io.read_fully(len_bytes)
length = (len_bytes[0].to_u32 << 16) | (len_bytes[1].to_u32 << 8) | len_bytes[2].to_u32
puts "Length: #{length}"

# Read Version
ver = io.read_bytes(UInt16, IO::ByteFormat::BigEndian)
puts "Version: 0x#{ver.to_s(16)}"

# Read Random
random = Bytes.new(32)
io.read_fully(random)

# Read Session ID
sess_id_len = io.read_byte.not_nil!
puts "Session ID Len: #{sess_id_len}"
sess_id = Bytes.new(sess_id_len)
io.read_fully(sess_id)

# Read Cipher Suites
ciphers_len = io.read_bytes(UInt16, IO::ByteFormat::BigEndian)
puts "Ciphers Len: #{ciphers_len}"
ciphers = Bytes.new(ciphers_len)
io.read_fully(ciphers)

# Read Compression Methods
comp_len = io.read_byte.not_nil!
puts "Compression Methods Len: #{comp_len}"
comp = Bytes.new(comp_len)
io.read_fully(comp)

# Read Extensions Length
ext_total_len = io.read_bytes(UInt16, IO::ByteFormat::BigEndian)
puts "Total Extensions Len: #{ext_total_len}"

# Iterate and parse extensions
while io.pos < io.size
  ext_type = io.read_bytes(UInt16, IO::ByteFormat::BigEndian) rescue break
  ext_len = io.read_bytes(UInt16, IO::ByteFormat::BigEndian) rescue break
  puts "Extension Type: #{ext_type} (0x#{ext_type.to_s(16)}), Len: #{ext_len}"
  io.skip(ext_len)
end
